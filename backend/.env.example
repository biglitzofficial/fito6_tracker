# Server
NODE_ENV=development
PORT=4000
JWT_SECRET=dev_secret_change_me_in_production_32chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Firebase — option A: service account file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Firebase — option B: full service account JSON (Railway)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase — option C: individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Email — Resend HTTPS API (recommended on Railway Hobby; SMTP is blocked)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Fito6 <onboarding@resend.dev>

# Email — SMTP fallback (works locally; blocked on Railway Hobby plan)
# SMTP_HOST=smtp.gmail.com
