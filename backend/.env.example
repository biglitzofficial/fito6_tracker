# Server
NODE_ENV=development
PORT=4000
JWT_SECRET=dev_secret_change_me_in_production_32chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Firebase — option A: service account file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Firebase — option B: full service account JSON (Railway)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase — option C: individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Email (required for admin forgot-password in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Fito6 <your-email@gmail.com>
