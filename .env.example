# Database (use pooled URL for app, direct URL for migrations)
DATABASE_URL=postgresql://user:password@localhost:5432/fito6_tracker
DIRECT_URL=postgresql://user:password@localhost:5432/fito6_tracker

# JWT — use a random string of at least 32 characters in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# First admin bootstrap (run once: npm run db:bootstrap-admin)
ADMIN_EMAIL=
ADMIN_NAME=Administrator
ADMIN_PASSWORD=

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
